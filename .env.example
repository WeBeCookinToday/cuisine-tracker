# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is git-ignored, so your keys never get committed.
#
# For LOCAL development, point these at your STAGING/test Supabase project
# so local testing never touches production data.
#
# These are also set per-environment in GitHub Actions (see README.md).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
